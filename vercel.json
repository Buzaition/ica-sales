{
  "installCommand": "corepack enable && corepack pnpm install --no-frozen-lockfile",
  "buildCommand": "corepack enable && corepack pnpm run build",
  "outputDirectory": "client/dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}