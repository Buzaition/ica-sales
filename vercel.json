{
  "installCommand": "corepack enable && corepack pnpm install",
  "buildCommand": "corepack enable && corepack pnpm run build",
  "outputDirectory": "client/dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/api",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
